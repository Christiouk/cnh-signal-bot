# ─── CNH Signal Bot — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit the .env file to version control.

# ── OpenAI API ────────────────────────────────────────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
# Note: This is separate from your ChatGPT Pro subscription.
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Pushover Notifications ────────────────────────────────────────────────────
# 1. Create a free account at: https://pushover.net
# 2. Your USER KEY is shown on your dashboard after login.
# 3. Create an Application at: https://pushover.net/apps/build
#    Name it "CNH Signal Bot" — this gives you the APP TOKEN.
PUSHOVER_TOKEN=your-pushover-app-token-here
PUSHOVER_USER=your-pushover-user-key-here
